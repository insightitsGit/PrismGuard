include README.md
include pyproject.toml
recursive-include prismguard *.yaml
recursive-include prismguard *.json
recursive-include prismguard *.onnx
recursive-include prismguard *.model
recursive-include prismguard *.md
recursive-include prismguard *.txt
recursive-include prismguard *.csv
recursive-include prismguard *.parquet
recursive-exclude * __pycache__
recursive-exclude * *.py[cod]
prune benchmark
prune tests
prune handoffs
prune scripts
prune docs
prune dist
prune build
prune .git
